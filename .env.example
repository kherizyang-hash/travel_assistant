# 差旅出行助手环境变量示例（复制为 .env 后填写）

# 必填：通义千问 API
DASHSCOPE_API_KEY=your_dashscope_key
MODEL=qwen-plus

# 必填（生产）：JWT 签名密钥，请使用随机长字符串
JWT_SECRET=change-me-to-a-long-random-string

# 可选：OpenWeather（weather MCP）
OPENWEATHER_API_KEY=

# 数据目录（Docker / Sealos 默认 /app/data）
DATA_DIR=./data

# 生产环境标识（未设置 JWT_SECRET 时开发模式会使用默认值）
ENV=production
