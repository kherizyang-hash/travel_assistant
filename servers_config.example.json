{
  "mcpServers": {
    "weather": {
      "command": "python",
      "args": ["weather_server.py"],
      "transport": "stdio"
    },
    "write": {
      "command": "python",
      "args": ["write_server.py"],
      "transport": "stdio"
    },
    "amap-maps": {
      "transport": "streamable_http",
      "url": "https://mcp.api-inference.modelscope.net/<your-amap-deployment-id>/mcp"
    },
    "12306-mcp": {
      "transport": "streamable_http",
      "url": "https://mcp.api-inference.modelscope.net/<your-12306-deployment-id>/mcp"
    },
    "variflight-mcp": {
      "transport": "streamable_http",
      "url": "https://mcp.api-inference.modelscope.net/<your-variflight-deployment-id>/mcp"
    }
  }
}
